{
  "$schema": "https://schema.tauri.app/config/2.0.0/capability",
  "identifier": "default",
  "description": "Default capability set for PDF Reader",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:scope-home-recursive",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive",
    "shell:default"
  ]
}
